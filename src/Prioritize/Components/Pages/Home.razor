@page "/"

@using System.Collections.Generic
@using Prioritize.Core.Enum
@using Prioritize.Core.Models
@using System.Collections.ObjectModel
@using Microsoft.JSInterop
@using Prioritize.Core.Services
@inject ITaskService _taskService

<div class="container">

    @if (!Tasks.Any())
    {
        <Prioritize.Components.Shared.Splash @bind-ShowAddTask="ShowAddTask"></Prioritize.Components.Shared.Splash>
    }
    else
    {
        @* <Prioritize.Components.Shared.FilterBar SelectedFilter="SelectedFilter"></Prioritize.Components.Shared.FilterBar> *@
        <Prioritize.Components.Shared.FilterBar @bind-SelectedFilter="SelectedFilter"></Prioritize.Components.Shared.FilterBar>

        <!-- Task list -->
        <ul class="list-group">
@*             @foreach (var task in Tasks.Where(task => FilterTask(task)).GroupBy(x => x.DueDate.Date))
            {
                <Prioritize.Components.Shared.TaskCard TaskItem="task" RemoveTaskCallback="GetTasks" MarkComplete="GetTasks"></Prioritize.Components.Shared.TaskCard>
            } *@
            @foreach (var taskGroup in Tasks.Where(task => FilterTask(task)).GroupBy(x => x.DueDate.Date))
            {
                <div class="mb-4 task-group">
                    <div class="d-flex align-items-center mb-2">
                        <h6 class="mb-0 fw-semibold text-muted">
                            @ToWrittenDate(taskGroup.Key)
                        </h6>
                        <hr class="flex-grow-1 ms-3 my-0" />
                    </div>

                    <div class="ps-2">
                        @foreach (var task in taskGroup)
                        {
                            <Prioritize.Components.Shared.TaskCard TaskItem="task"
                                                                   RemoveTaskCallback="GetTasks"
                                                                   MarkComplete="GetTasks" />
                        }
                    </div>
                </div>

            }
        </ul>

        <!-- Floating Add Button -->
        <button class="floating-add-btn" @onclick="@(() => ShowAddTask = true)">+</button>

        
    }

    <!-- Add Task Modal -->
    @if (ShowAddTask)
    {
        <Prioritize.Components.Shared.AddTaskModal @bind-ShowAddTask="ShowAddTask" RefreshTaskList="GetTasks"></Prioritize.Components.Shared.AddTaskModal>
    }

</div>


@code {
    private TaskFilter SelectedFilter = TaskFilter.Incomplete;

    private List<TaskItem> Tasks = new List<TaskItem>();

    private bool ShowAddTask = false;

    protected override async Task OnInitializedAsync()
    {
        await GetTasks();
    }

    private async Task GetTasks() 
    {
        var tasks = await _taskService.GetTasks();

        Tasks = tasks.ToList();
    }


    private bool FilterTask(TaskItem task)
    {
        return SelectedFilter switch
        {
            TaskFilter.Incomplete => !task.IsCompleted,            // show only incomplete tasks
            TaskFilter.Completed => task.IsCompleted,
            TaskFilter.Tomorrow => task.Due == TaskFilter.Tomorrow && !task.IsCompleted,
            TaskFilter.Soon => task.Due == TaskFilter.Soon && !task.IsCompleted,
            TaskFilter.NearFuture => task.Due == TaskFilter.NearFuture && !task.IsCompleted,
            TaskFilter.All => true,
            _ => true
        };
    }

    static string ToWrittenDate(DateTimeOffset dto)
    {
        var date = dto.Date;
        return $"{date.Day}{GetOrdinalSuffix(date.Day)} {date:MMMM yyyy}";
    }

    static string GetOrdinalSuffix(int day)
    {
        if (day is >= 11 and <= 13)
            return "th";

        return (day % 10) switch
        {
            1 => "st",
            2 => "nd",
            3 => "rd",
            _ => "th"
        };
    }

}
