@page "/"

@using System.Collections.Generic
@using Prioritize.Core.Enum
@using Prioritize.Core.Models
@using System.Collections.ObjectModel
@using Microsoft.JSInterop

<div class="container">

    <!-- Filter Bar -->
    <div class="todo-filters">
        <div class="filter-item @(SelectedFilter == TaskFilter.Incomplete ? "active" : "")"
             @onclick="() => SelectedFilter = TaskFilter.Incomplete" title="Incomplete">
            ❌ Incomplete
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.Tomorrow ? "active" : "")"
             @onclick="() => SelectedFilter = TaskFilter.Tomorrow" title="Tomorrow">
            📅 Tomorrow
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.Soon ? "active" : "")"
             @onclick="() => SelectedFilter = TaskFilter.Soon" title="Soon">
            ⏳ Soon
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.NearFuture ? "active" : "")"
             @onclick="() => SelectedFilter = TaskFilter.NearFuture" title="Near Future">
            🔮 Near Future
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.Completed ? "active" : "")"
             @onclick="() => SelectedFilter = TaskFilter.Completed" title="Completed">
            ✅ Completed
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.All ? "active" : "")"
             @onclick="() => SelectedFilter = TaskFilter.All" title="All">
            🗂️ All
        </div>
    </div>


    <!-- Task list -->
    <ul class="list-group">
        @foreach (var task in Tasks.Where(task => FilterTask(task)))
        {
            <li class="list-group-item task-item @(task.IsExpanded ? "expanded" : "")">


                <div class="task-header d-flex justify-content-between align-items-center">
                    <div class="task-left d-flex align-items-center gap-2">
                        <input type="checkbox" class="task-complete" @bind="task.IsCompleted" />
                        <span class="task-title" style="@(task.IsCompleted ? "text-decoration: line-through; color:#999;" : "")">
                            @task.Title
                        </span>
                    </div>
                    <div class="task-actions">
                        <button class="btn btn-sm btn-secondary" @onclick="() => ToggleDetails(task)">
                            @(task.IsExpanded ? "▾" : "▸")
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => RemoveTask(task)">×</button>
                    </div>
                </div>
                @if (task.IsExpanded)
                {
                    <div class="task-details">
                        <p><strong>Due:</strong> @task.DueDate</p>
                        <p><strong>Notes:</strong> @task.Notes</p>
                    </div>
                }
            </li>
        }
    </ul>

    <!-- Floating Add Button -->
    <button class="floating-add-btn" @onclick="@(() => ShowAddTask = true)">+</button>

    <!-- Add Task Modal -->
    @if (ShowAddTask)
    {
        <div class="modal-overlay" @onclick="() => ShowAddTask = false">
            <div class="modal-content" @onclick:stopPropagation>
                <h3>Add New Task</h3>
                <input placeholder="Task title" @bind="NewTaskTitle" />
                <input type="datetime-local" placeholder="Due date" @bind="NewDueDate" />
                @* <InputDate TValue="NewDueDate" @bind="NewDueDate" ></InputDate> *@
                <textarea placeholder="Notes" @bind="NewTaskNotes"></textarea>
                <div class="modal-buttons">
                    <button class="btn btn-primary" @onclick="AddTask">Add</button>
                    <button class="btn btn-secondary" @onclick="() => ShowAddTask = false">Cancel</button>
                </div>
            </div>
        </div>
    }
</div>



@code {
    private TaskFilter SelectedFilter = TaskFilter.Incomplete;

    private bool ShowAddTask = false;
    private string NewTaskTitle = "";
    private string NewTaskDueDate = "";
    private string NewTaskNotes = "";

    private DateTimeOffset NewDueDate { get; set; } = DateTime.UtcNow;

    private List<TaskItem> Tasks = new List<TaskItem>
    {
        new TaskItem { Title = "Placeholder Task 1", Due = TaskFilter.Tomorrow, DueDate = "Tomorrow", Notes = "Some notes" },
        new TaskItem { Title = "Placeholder Task 2", Due = TaskFilter.Soon, DueDate = "Next Week", Notes = "Some notes" },
        new TaskItem { Title = "Placeholder Task 3", Due = TaskFilter.NearFuture, DueDate = "Next Month", Notes = "Some notes" }
    };

    private void ToggleDetails(TaskItem task)
    {
        task.IsExpanded = !task.IsExpanded;
        StateHasChanged();
    }

    private void RemoveTask(TaskItem task)
    {
        Tasks.Remove(task);
    }

    private void AddTask()
    {
        if (!string.IsNullOrWhiteSpace(NewTaskTitle))
        {
            Tasks.Add(new TaskItem
            {
                Title = NewTaskTitle,
                Due = TaskFilter.NearFuture, // default due type
                DueDate = NewTaskDueDate,
                Notes = NewTaskNotes
            });
        }

        NewTaskTitle = "";
        NewTaskDueDate = "";
        NewTaskNotes = "";
        ShowAddTask = false;
    }

    private bool FilterTask(TaskItem task)
    {
        return SelectedFilter switch
        {
            TaskFilter.Incomplete => !task.IsCompleted,            // show only incomplete tasks
            TaskFilter.Completed => task.IsCompleted,
            TaskFilter.Tomorrow => task.Due == TaskFilter.Tomorrow && !task.IsCompleted,
            TaskFilter.Soon => task.Due == TaskFilter.Soon && !task.IsCompleted,
            TaskFilter.NearFuture => task.Due == TaskFilter.NearFuture && !task.IsCompleted,
            TaskFilter.All => true,
            _ => true
        };
    }
}
