@using Prioritize.Core.Models
@using Prioritize.Core.Services
@inject ITaskService _taskService

@* <li class="list-group-item task-item @(TaskItem.IsExpanded ? "expanded" : "")"> *@
 <ul class="list-group">
    <li class="d-flex align-items-start gap-2 task-row">

        <!-- Checkbox outside the card -->
        <input type="checkbox"
               class="task-complete mt-3"
               checked="@TaskItem.IsCompleted"
               @onchange="MarkTaskComplete" />

        <!-- Card container -->
        <div class="list-group-item task-item task-card flex-grow-1 @(TaskItem.IsExpanded ? "expanded" : "")"
             @onclick="() => ToggleDetails(TaskItem)">

            <div class="task-header d-flex align-items-center justify-content-between">
                <div class="task-left d-flex align-items-center gap-2">
                    <span class="expand-caret me-1">
                        @(TaskItem.IsExpanded ? "▾" : "▸")
                    </span>
                    <span class="task-title">
                        @TaskItem.Title
                    </span>
                </div>

                <!-- Action buttons -->
                <div class="task-actions d-flex gap-2">
                    <button class="btn btn-sm btn-light edit-btn"
                            title="Edit task"
                            @onclick="EditClicked"
                            @onclick:stopPropagation>
                        ✏️
                    </button>
                    <button class="btn btn-sm btn-danger"
                            @onclick="async () => await RemoveTask(TaskItem)"
                            @onclick:stopPropagation>
                        ×
                    </button>
                </div>

            </div>

            @if (TaskItem.IsExpanded)
            {
                <div class="task-details mt-2">
                    <div class="task-divider mb-2"></div>
                    <div class="task-detail-row">
                        <strong>Due:</strong> @TaskItem.DueDateString
                    </div>
                    @if (!string.IsNullOrWhiteSpace(TaskItem.Notes))
                    {
                        <div class="task-detail-row">
                            <strong>Notes:</strong> @TaskItem.Notes
                        </div>
                    }

                </div>
            }

        </div>
    </li>


 </ul>

@code {
    [Parameter] public TaskItem TaskItem { get; set; }
    [Parameter] public EventCallback<TaskItem> RemoveTaskCallback { get; set; }
    [Parameter] public EventCallback<TaskItem> MarkComplete { get; set; }
    [Parameter] public EventCallback<TaskItem> OnEdit { get; set; }
    [Parameter] public EventCallback<TaskItem> OnClick { get; set; }

    private async Task RemoveTask(TaskItem task)
    {
        await _taskService.RemoveTask(task);

        await RemoveTaskCallback.InvokeAsync(task);
    }

    private void ToggleDetails(TaskItem task)
    {
        task.IsExpanded = !task.IsExpanded;
        OnClick.InvokeAsync(task);
        StateHasChanged();
    }

    private async Task MarkTaskComplete(ChangeEventArgs e)
    {
        TaskItem.IsCompleted = (bool)e.Value!;
        await _taskService.ToggleComplete(TaskItem);

        await MarkComplete.InvokeAsync(TaskItem);
    }

    private async Task EditClicked()
    {
        if (OnEdit.HasDelegate)
            await OnEdit.InvokeAsync(TaskItem);
    }


}