@using Prioritize.Core.Enum
@using Prioritize.Core.Models
@using Prioritize.Core.Services
@inject ITaskService _taskService
@inject INotificationManagerService _notificationManager

@if (ShowAddTask)
{
<div class="modal-overlay" @onclick="CloseModal">
    <div class="modal-container" @onclick:stopPropagation="true">
        <!-- Header -->
        <div class="modal-header">
            <h3>@(IsEditMode ? "Edit Task" : "Add New Task")</h3>
            <button class="close-btn" @onclick="CloseModal">✕</button>
        </div>

        <!-- Body -->
        <div class="modal-body">

            <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <!-- Title -->
                <div class="section">
                    <h4>Task</h4>
                    <input
                        class="input"
                        placeholder="What needs to be done?"
                        @bind="TaskModel.Title" />
                    <ValidationMessage For="@(() => TaskModel.Title)" />
                </div>

                <!-- Due Date -->
                <div class="section">
                    <h4>Due Date</h4>
                    <input
                        type="datetime-local"
                        class="input"
                        @bind="TaskModel.DueDate" />
                </div>

                <!-- Notes -->

                    <div class="section">
                        <h4>Notes</h4>
                        <textarea class="input"
                                  placeholder="Optional: additional details"
                                  @bind="TaskModel.Notes">
                        </textarea>
                    </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button type="button" class="btn secondary" @onclick="CloseModal">
                        Cancel
                    </button>
                    <button type="submit" class="btn primary">
                        @(IsEditMode ? "Save Changes" : "Add Task")
                    </button>
                </div>

            </EditForm>

        </div>

    </div>
</div>
}

@code {
    [Parameter] public TaskItem? EditingTask { get; set; }
    [Parameter] public EventCallback RefreshTaskList { get; set; }
    [Parameter] public EventCallback<bool> ShowAddTaskChanged { get; set; }
    [Parameter] public bool ShowAddTask { get; set; }

    private TaskItem TaskModel { get; set; } = CreateBlankTask();
    private bool IsEditMode => EditingTask != null;
    private EditContext? _editContext;

    private static TaskItem CreateBlankTask() => new TaskItem() { DueDate = DateTimeOffset.UtcNow };

    protected override void OnParametersSet()
    {
        if (EditingTask != null)
        {
            TaskModel = new TaskItem
            {
                Id = EditingTask.Id,
                Title = EditingTask.Title,
                Due = EditingTask.Due,
                DueDate = EditingTask.DueDate,
                Notes = EditingTask.Notes
            };
        }
        else
        {
            TaskModel = CreateBlankTask();
        }

        _editContext = new EditContext(TaskModel);
    }

    private async Task AddTask()
    {
        if (!string.IsNullOrWhiteSpace(TaskModel.Title))
        {
            var newTask = new TaskItem
            {
                Title = TaskModel.Title,
                Due = TaskFilter.NearFuture, // default due type
                DueDate = TaskModel.DueDate,
                Notes = TaskModel.Notes
            };

            await _taskService.AddTask(newTask);
        }

        await CloseModal();

        TaskModel = CreateBlankTask();

        await RefreshTaskList.InvokeAsync();
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(TaskModel.Title))
            return;

        if (IsEditMode)
        {
            await _taskService.UpdateTask(TaskModel);
        }
        else
        {
            TaskModel.Due = TaskFilter.NearFuture;
            await _taskService.AddTask(TaskModel);
        }

        TaskModel = CreateBlankTask();

        var userName = Preferences.Get("username", null);
        var message = string.Empty;

        if (userName is not null)
        {
            message = $"{userName} - a task is approaching it's due date!";
        } else
        {
            message = "A task is approaching it's due date";
        }

        _notificationManager.SendNotification(message, TaskModel.Title, DateTime.Now.AddSeconds(10));
        _notificationManager.SendNotification(message, TaskModel.Title, TaskModel.DueDate.Date.AddDays(-1));

        await CloseModal();
        await RefreshTaskList.InvokeAsync();
    }


    private async Task CloseModal()
    {
        await ShowAddTaskChanged.InvokeAsync(false);
    }
}
