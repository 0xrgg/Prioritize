@using Prioritize.Core.Enum


<div class="todo-filters-container">

    <!-- Desktop buttons -->
    <div class="todo-filters desktop-only">
        <div class="filter-item @(SelectedFilter == TaskFilter.Incomplete ? "active" : "")"
             @onclick="() => SelectFilter(TaskFilter.Incomplete)">
            ❌ Incomplete
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.Tomorrow ? "active" : "")"
             @onclick="() => SelectFilter(TaskFilter.Tomorrow)">
            📅 Tomorrow
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.Soon ? "active" : "")"
             @onclick="() => SelectFilter(TaskFilter.Soon)">
            ⏳ Soon
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.NearFuture ? "active" : "")"
             @onclick="() => SelectFilter(TaskFilter.NearFuture)">
            🔮 Near Future
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.Completed ? "active" : "")"
             @onclick="() => SelectFilter(TaskFilter.Completed)">
            ✅ Completed
        </div>
        <div class="filter-item @(SelectedFilter == TaskFilter.All ? "active" : "")"
             @onclick="() => SelectFilter(TaskFilter.All)">
            🗂️ All
        </div>
    </div>

    <!-- Mobile dropdown button -->
    <div class="mobile-only dropdown-container mb-4">
        <button class="filter-dropdown-toggle filter-item" @onclick="ToggleDropdown">
            @SelectedFilterIcon @SelectedFilterText
            <span class="dropdown-arrow">▾</span>
        </button>
        @if (!Hide)
        {
            <div class="dropdown-menu">
                <div class="filter-item @(SelectedFilter == TaskFilter.Incomplete ? "active" : "")"
                     @onclick="() => SelectFilter(TaskFilter.Incomplete)">
                    ❌ Incomplete
                </div>
                <div class="filter-item @(SelectedFilter == TaskFilter.Tomorrow ? "active" : "")"
                     @onclick="() => SelectFilter(TaskFilter.Tomorrow)">
                    📅 Tomorrow
                </div>
                <div class="filter-item @(SelectedFilter == TaskFilter.Soon ? "active" : "")"
                     @onclick="() => SelectFilter(TaskFilter.Soon)">
                    ⏳ Soon
                </div>
                <div class="filter-item @(SelectedFilter == TaskFilter.NearFuture ? "active" : "")"
                     @onclick="() => SelectFilter(TaskFilter.NearFuture)">
                    🔮 Near Future
                </div>
                <div class="filter-item @(SelectedFilter == TaskFilter.Completed ? "active" : "")"
                     @onclick="() => SelectFilter(TaskFilter.Completed)">
                    ✅ Completed
                </div>
                <div class="filter-item @(SelectedFilter == TaskFilter.All ? "active" : "")"
                     @onclick="() => SelectFilter(TaskFilter.All)">
                    🗂️ All
                </div>
            </div>
        }
    </div>
</div>



@code {
    [Parameter] public TaskFilter SelectedFilter { get; set; } = TaskFilter.All;
    [Parameter] public EventCallback<TaskFilter> SelectedFilterChanged { get; set; }
    [Parameter] public bool Hide { get; set; } = true;
    [Parameter] public EventCallback OnFilterOpened { get; set; }

    private bool DropdownOpen { get; set; } = false;

    public void HideDropdown() {
        Hide = true;
    }

    private void ToggleDropdown()
    {
        //DropdownOpen = !DropdownOpen;
        Hide = !Hide;
        OnFilterOpened.InvokeAsync();
        StateHasChanged();
    }

    private async Task SelectFilter(TaskFilter filter)
    {
        SelectedFilter = filter;
        //DropdownOpen = false;
        Hide = true;

        await SelectedFilterChanged.InvokeAsync(SelectedFilter);
    }

    // Optional: show the icon + text of selected filter in the toggle button
    private string SelectedFilterIcon => SelectedFilter switch
    {
        TaskFilter.Incomplete => "❌",
        TaskFilter.Tomorrow => "📅",
        TaskFilter.Soon => "⏳",
        TaskFilter.NearFuture => "🔮",
        TaskFilter.Completed => "✅",
        TaskFilter.All => "🗂️",
        _ => ""
    };

    private string SelectedFilterText => SelectedFilter.ToString();
}